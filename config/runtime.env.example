# Runtime environment variables for local development or manual installs.
# Export these in your shell or place them into a local env file consumed by Docker Compose.

NAGIENT_HOME=$HOME/.nagient
NAGIENT_CONFIG=$HOME/.nagient/config.toml
NAGIENT_SECRETS_FILE=$HOME/.nagient/secrets.env
NAGIENT_TOOL_SECRETS_FILE=$HOME/.nagient/tool-secrets.env
NAGIENT_PROMPTS_DIR=$HOME/.nagient/prompts
NAGIENT_PLUGINS_DIR=$HOME/.nagient/plugins
NAGIENT_TOOLS_DIR=$HOME/.nagient/tools
NAGIENT_PROVIDERS_DIR=$HOME/.nagient/providers
NAGIENT_CREDENTIALS_DIR=$HOME/.nagient/credentials
NAGIENT_STATE_DIR=$HOME/.nagient/state
NAGIENT_LOG_DIR=$HOME/.nagient/logs
NAGIENT_RELEASES_DIR=$HOME/.nagient/releases
NAGIENT_WORKSPACE_ROOT=
NAGIENT_WORKSPACE_MODE=bounded
NAGIENT_CHANNEL=stable
NAGIENT_UPDATE_BASE_URL=https://updates.your-domain.tld
NAGIENT_HEARTBEAT_INTERVAL=30
NAGIENT_DOCKER_PROJECT_NAME=nagient
NAGIENT_SAFE_MODE=true
NAGIENT_AGENT_DEFAULT_PROVIDER=
NAGIENT_AGENT_REQUIRE_PROVIDER=false
NAGIENT_AGENT__SYSTEM_PROMPT_FILE=
NAGIENT_AGENT__MAX_TURNS=4
NAGIENT_AGENT_MEMORY__HARD_MESSAGE_LIMIT=100
NAGIENT_AGENT_MEMORY__DYNAMIC_FOCUS_ENABLED=true
NAGIENT_AGENT_MEMORY__DYNAMIC_FOCUS_MESSAGES=10
NAGIENT_AGENT_MEMORY__SUMMARY_TRIGGER_MESSAGES=20
NAGIENT_AGENT_MEMORY__RETRIEVAL_MAX_RESULTS=8
NAGIENT_AGENT_LOGGING__LEVEL=info
NAGIENT_AGENT_LOGGING__JSON_LOGS=false
NAGIENT_AGENT_LOGGING__LOG_EVENTS=true
# Example transport env overrides:
# NAGIENT_TRANSPORT__TELEGRAM__PLUGIN=builtin.telegram
# NAGIENT_TRANSPORT__TELEGRAM__ENABLED=true
# NAGIENT_TRANSPORT__TELEGRAM__BOT_TOKEN_SECRET=TELEGRAM_BOT_TOKEN
# NAGIENT_TRANSPORT__TELEGRAM__DEFAULT_CHAT_ID=1522105862
# Example tool env overrides:
# NAGIENT_TOOL__TRANSPORT_ROUTER__ENABLED=true
# NAGIENT_TOOL__AGENT_MEMORY__ENABLED=true
# NAGIENT_TOOL__SYSTEM_JOBS__ENABLED=true
# NAGIENT_TOOL__GITHUB_API__PLUGIN=github.api
# NAGIENT_TOOL__GITHUB_API__ENABLED=true
# NAGIENT_TOOL__GITHUB_API__TOKEN_SECRET=GITHUB_TOKEN
# NAGIENT_TOOL__WORKSPACE_GIT__AUTHOR_NAME=Nagient Agent
# NAGIENT_TOOL__WORKSPACE_GIT__AUTHOR_EMAIL=agent@example.com
# NAGIENT_TOOL__WORKSPACE_GIT__USERNAME=git-user
# NAGIENT_TOOL__WORKSPACE_GIT__TOKEN_SECRET=GIT_ACCESS_TOKEN
# Example provider env overrides:
# NAGIENT_PROVIDER__OPENAI__PLUGIN=builtin.openai
# NAGIENT_PROVIDER__OPENAI__ENABLED=true
# NAGIENT_PROVIDER__OPENAI__AUTH=api_key
# NAGIENT_PROVIDER__OPENAI__API_KEY_SECRET=OPENAI_API_KEY
# NAGIENT_PROVIDER__OPENAI__MODEL=gpt-4.1-mini
