# Секреты Nagient. Скопируйте в data/secrets.env только нужные строки.
# Не коммитьте этот файл с реальными значениями.

# Провайдеры моделей:
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# DEEPSEEK_API_KEY=
# GEMINI_API_KEY=
# CODEX_API_KEY=

# Транспорты и инструменты:
# TELEGRAM_BOT_TOKEN=
# NAGIENT_WEBHOOK_SHARED_SECRET=
# GITHUB_TOKEN=
