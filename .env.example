# Nagient self-hosted deployment — Docker Compose overrides.
#
# Copy this file to .env and adjust as needed:
#   cp .env.example .env
#
# All values are optional; the defaults in docker-compose.yml work out of the box.
# Secrets (API keys, bot tokens) do NOT go here — put them in ./data/secrets.env
# after the first `docker compose up`.

# Published image to run. Pin a specific version for reproducible deploys,
# e.g. docker.io/parampo/nagient:0.8.8
NAGIENT_IMAGE=docker.io/parampo/nagient:latest

# Container name shown in `docker ps`.
NAGIENT_CONTAINER_NAME=nagient

# Runtime heartbeat interval in seconds.
NAGIENT_HEARTBEAT_INTERVAL=30

# Safe mode keeps workspace path guards strict. Set to false only if you
# understand the implications of relaxed path guarding.
NAGIENT_SAFE_MODE=true
