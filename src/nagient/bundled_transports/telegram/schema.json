{
  "type": "object",
  "properties": {
    "bot_token_secret": {
      "type": "string"
    },
    "default_chat_id": {
      "type": ["string", "integer"]
    },
    "default_parse_mode": {
      "type": "string",
      "enum": ["MarkdownV2", "HTML", "Markdown"]
    },
    "poll_timeout_seconds": {
      "type": "integer",
      "minimum": 1
    },
    "timeout_seconds": {
      "type": "integer",
      "minimum": 1
    },
    "proxy_url": {
      "type": "string"
    },
    "proxy_username": {
      "type": "string"
    },
    "proxy_password_secret": {
      "type": "string"
    },
    "allowed_chat_ids": {
      "type": ["array", "string"],
      "items": { "type": ["string", "integer"] }
    },
    "allowed_user_ids": {
      "type": ["array", "string"],
      "items": { "type": ["string", "integer"] }
    },
    "allowed_chat_types": {
      "type": ["array", "string"],
      "items": { "type": "string" }
    },
    "stream_updates": {
      "type": "boolean"
    },
    "stream_edit_interval_seconds": {
      "type": "number",
      "minimum": 0.5
    }
  },
  "required": ["bot_token_secret"]
}
